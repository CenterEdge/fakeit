    "events-async": "~1.1.0",
    "faker": "^3.1.0",
    "find-root": "~1.0.0",
    "format-seconds": "~0.3.1",
    "fs-extra-promisify": "^0.0.2",
    "globby": "^6.1.0",
    "highlight-es": "~1.0.0",
    "lodash": "^4.17.21",
    "log-symbols": "~1.0.2",
